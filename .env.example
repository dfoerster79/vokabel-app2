# Supabase – URL des Projekts
VITE_SUPABASE_URL=https://xxxx.supabase.co

# Publishable Key (sicher fuer den Browser, ersetzt alten anon-Key)
# Zu finden in: Supabase → Project Settings → API → Publishable and secret API keys
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret Key (NUR serverseitig / Vercel Serverless Functions – NIEMALS im Frontend verwenden!)
# Zu finden in: Supabase → Project Settings → API → Publishable and secret API keys → Secret
SUPABASE_SECRET_KEY=sb_secret_...
